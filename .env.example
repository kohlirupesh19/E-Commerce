# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Frontend newsletter integration (Supabase)
# Required: paste your Supabase anon/public API key.
# Optional: set VITE_SUPABASE_URL. If omitted, the app derives it from the API key issuer.
VITE_SUPABASE_API_KEY="YOUR_SUPABASE_ANON_KEY"
VITE_SUPABASE_URL=""

# API service (Phase 0 scaffold)
API_PORT="4000"
API_HOST="0.0.0.0"
CORS_ORIGIN="http://localhost:3000"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/obsidian_curator"
REDIS_URL="redis://localhost:6379"
JWT_ACCESS_SECRET="replace_me_access_secret"
JWT_REFRESH_SECRET="replace_me_refresh_secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
CHECKOUT_TAX_RATE="0.08"
CHECKOUT_DEFAULT_SHIPPING="0"
STRIPE_SECRET_KEY="sk_test_replace_me"
STRIPE_WEBHOOK_SECRET="whsec_replace_me"

# Worker service (Phase 0 scaffold)
WORKER_CONCURRENCY="5"
WORKER_QUEUE_PREFIX="obsidian-curator"
